{
  "name": "techvault3",
  "version": "1.0.0",
  "description": "TechVault3 — Production-grade e-commerce backend",
  "main": "server/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "seed": "node server/scripts/seed.js",
    "seed:force": "node server/scripts/seed.js --force",
    "seed:keyboards": "node server/scripts/seedKeyboards.js",
    "seed:keyboards:force": "node server/scripts/seedKeyboards.js --force",
    "debug:keyboards": "node server/scripts/debugKeyboards.js",
    "seed:monitors": "node server/scripts/seedMonitors.js",
    "seed:monitors:force": "node server/scripts/seedMonitors.js --force",
    "debug:monitors": "node server/scripts/debugMonitors.js",
    "seed:mice": "node server/scripts/seedMice.js",
    "seed:mice:force": "node server/scripts/seedMice.js --force",
    "debug:mice": "node server/scripts/debugMice.js",
    "audit:mice-prices": "node server/scripts/auditMousePrices.js",
    "seed:desktops": "node server/scripts/seedDesktops.js",
    "seed:desktops:force": "node server/scripts/seedDesktops.js --force",
    "debug:desktops": "node server/scripts/debugDesktops.js",
    "audit:desktop-prices": "node server/scripts/auditDesktopPrices.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand --forceExit",
    "update:prices": "node server/scripts/updatePrices.js",
    "audit:catalog-prices": "node server/scripts/auditCatalogPrices.js",
    "seed:headphones": "node server/scripts/seedHeadphones.js",
    "seed:headphones:force": "node server/scripts/seedHeadphones.js --force",
    "debug:headphones": "node server/scripts/debugHeadphones.js",
    "audit:headphone-prices": "node server/scripts/auditHeadphonePrices.js",
    "cleanup:mock-products": "node server/scripts/cleanupMockProducts.js",
    "lint": "eslint server/ tests/",
    "load:smoke": "node devops/load-tests/public-smoke.js",
    "load:test": "node devops/load-tests/public-load.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.3",
    "prom-client": "^15.1.2",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^6.0.2",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.2",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "verbose": true,
    "globalSetup": "./tests/helpers/globalSetup.js",
    "globalTeardown": "./tests/helpers/globalTeardown.js",
    "setupFiles": [
      "./tests/helpers/testEnv.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/client/"
    ]
  }
}
