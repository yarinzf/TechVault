# Dependencies
node_modules/

# Environment files
.env
.env.*
!.env.example
!.env.docker.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Uploads / Generated files
uploads/
coverage/
dist/
.tmp/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor files
.vscode/
.claude/

# Docker
docker-data/

# Terraform — never commit real state or variable values
devops/terraform/.terraform/
devops/terraform/.terraform.lock.hcl
devops/terraform/terraform.tfstate
devops/terraform/terraform.tfstate.backup
devops/terraform/tfplan
devops/terraform/*.tfvars
!devops/terraform/*.tfvars.example

# Ansible — never commit real inventory or vault passwords
devops/ansible/inventory.ini
devops/ansible/.vault_password