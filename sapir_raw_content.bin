        <span class="footer-link">\uc0\u1492 \u1494 \u1502 \u1504 \u1493 \u1514  \u1513 \u1500 \u1497 </span>\
        <span class="footer-link">\uc0\u1502 \u1493 \u1506 \u1491 \u1508 \u1497 \u1501 </span>\
