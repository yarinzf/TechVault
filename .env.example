# ─── Local development (.env) ────────────────────────
# For Docker, copy .env.docker.example → .env.docker instead.
# ─── App ────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ─── MongoDB ─────────────────────────────────────────
MONGO_URI_DEV=mongodb://localhost:27017/techvault
MONGO_URI_PROD=mongodb+srv://<user>:<pass>@cluster.mongodb.net/techvault

# ─── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_must_be_at_least_32chars
JWT_REFRESH_SECRET=change_me_refresh_secret_must_be_at_least_32chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Cookies ─────────────────────────────────────────
COOKIE_SECRET=change_me_cookie_secret_must_be_at_least_32chars

# ─── Tax ─────────────────────────────────────────────
TAX_RATE=0.17

# ─── CORS ────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://techvault.com

# ─── Frontend URL (used in email links, e.g. password reset) ─
FRONTEND_URL=http://localhost:3000

# ─── Email (Nodemailer) ───────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@techvault.com

# ─── Upload ──────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5

# ─── Stripe (stub — no live key needed) ──────────────
STRIPE_SECRET_KEY=sk_test_stub

# ─── Admin / Alerts ──────────────────────────────────
LOW_STOCK_THRESHOLD=5
# Raise an alert if >= N refunds happen within 24 hours
ALERT_REFUND_SPIKE_THRESHOLD=5

# ─── Background Jobs ─────────────────────────────────
# Clear items from carts inactive for this many days
CART_CLEANUP_DAYS=30

# ─── Feature Flags ────────────────────────────────────
# Set to 'false' to disable a module (returns 503 to clients)
FEATURE_REVIEWS=true
FEATURE_COUPONS=true
FEATURE_WISHLIST=true
FEATURE_NOTIFICATIONS=true
FEATURE_AUDIT_LOGS=true

# ─── Monitoring ──────────────────────────────────────
METRICS_PATH=/metrics
