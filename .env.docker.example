# ── TechVault Docker environment ─────────────────────────────────────────────
# Copy this file to .env.docker and fill in real values before running Docker.
# MONGO_URI_PROD is injected by docker-compose.yml; do not set it here unless
# you want to point to an external MongoDB instance.

NODE_ENV=production
PORT=5000
API_VERSION=v1

# ── JWT (REQUIRED — min 32 chars each) ───────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_a_real_secret_at_least_32_chars_long_here
JWT_REFRESH_SECRET=replace_with_another_real_secret_min_32_chars_long_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cookies (REQUIRED — min 32 chars) ────────────────────────────────────────
COOKIE_SECRET=replace_with_a_real_cookie_secret_min_32_chars_long_here

# ── CORS / URLs ───────────────────────────────────────────────────────────────
# Browser connects to the nginx frontend container; same-origin proxy avoids CORS
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Tax ───────────────────────────────────────────────────────────────────────
TAX_RATE=0.17

# ── Email (optional — leave blank to disable transactional email) ─────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@techvault.com

# ── Stripe (stub values keep the app running without a real Stripe account) ───
STRIPE_SECRET_KEY=sk_test_stub
STRIPE_WEBHOOK_SECRET=whsec_stub

# ── Frontend build args (consumed by docker-compose → client Dockerfile ARG) ──
VITE_STRIPE_PUBLIC_KEY=pk_test_stub
VITE_GOOGLE_CLIENT_ID=
