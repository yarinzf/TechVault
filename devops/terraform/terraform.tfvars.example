# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit real values.

aws_region       = "us-east-1"
instance_type    = "t3.small"
key_pair_name    = "your-key-pair-name"   # Must exist in AWS EC2 → Key Pairs before apply
allowed_ssh_cidr = "YOUR.IP.HERE/32"      # e.g. "203.0.113.42/32" — find yours at whatismyip.com
app_name         = "techvault"
volume_size_gb   = 20
